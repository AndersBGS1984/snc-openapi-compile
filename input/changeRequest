{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChangeRequest",
  "type": "object",
  "required": ["number", "state"],
  "properties": {
    "number": { "type": "string", "pattern": "^CHG[0-9]{7}$" },
    "state":  { "type": "string", "enum": ["-5", "1", "2", "3", "4", "-1"] }
  }
}
